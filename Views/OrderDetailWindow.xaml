<Window x:Class="Shoes.Views.OrderDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes.Views"
        mc:Ignorable="d"
        Title="Создать новый заказ"
        Height="600"
        Width="450"
        Icon="/Resources/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="8*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="/Resources/Icon.png"
                   Width="32"
                   Height="32"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   Margin="10 0 0 0" />

            <TextBlock Name="title"
                       Grid.Column="1"
                       Text="Новый заказ"
                       FontWeight="Bold"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Margin="15 0 0 0" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,15">
                <TextBlock Name="idBlock"
                           Text="Id"
                           Margin="0 12 0 3" />
                <TextBox   Name="idTextBox"
                           IsReadOnly="True"
                           Margin="0 0 0 12" />

                <TextBlock Text="Артикул товара"
                           Margin="0 0 0 3" />
                <ComboBox  Name="articleComboBox"
                           Padding="5"
                           Margin="0 0 0 12"
                           SelectedValuePath="Id"
                           DisplayMemberPath="Article" />

                <TextBlock Text="Статус заказ"
                           Margin="0 0 0 3" />
                <ComboBox  Name="statusComboBox"
                           Padding="5"
                           Margin="0 0 0 12"
                           SelectedValuePath="Id"
                           DisplayMemberPath="Name" />

                <TextBlock Text="Адрес пункта выдачи"
                           Margin="0 0 0 3" />
                <ComboBox  Name="addressComboBox"
                           Padding="5"
                           Margin="0 0 0 12"
                           SelectedValuePath="Id"
                           DisplayMemberPath="FullAddress" />

                <TextBlock Text="Дата заказа"
                           Margin="0 0 0 3" />
                <DatePicker Name="orderDateDatePicker"
                            Margin="0 0 0 12" />

                <TextBlock Text="Дата выдачи"
                           Margin="0 0 0 3" />
                <DatePicker Name="deliveryDateDatePicker"
                            Margin="0 0 0 12" />

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Name="deleteButton"
                    Content="Удалить"
                    Padding="10"
                    Margin="10"
                    BorderThickness="0"
                    Background="OrangeRed"
                    Click="DeleteClick" />

            <Button Content="Отмена"
                    Padding="10"
                    Margin="10"
                    Background="Transparent"
                    Click="CancelClick" />

            <Button Content="Сохранить"
                    Padding="10"
                    Margin="10"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="SaveClick" />

        </StackPanel>
    </Grid>
</Window>
