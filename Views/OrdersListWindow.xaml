<Window x:Class="Shoes.Views.OrdersListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes.Views"
        mc:Ignorable="d"
        Title="Список заказов"
        Height="450"
        Width="800"
        Icon="/Resources/Icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#7FFF00">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="/Resources/Icon.png"
                   Width="32"
                   Height="32"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   Margin="10 0 0 0" />

            <TextBlock Grid.Column="1"
                       Text="Список заказов"
                       FontWeight="Bold"
                       FontSize="24"
                       VerticalAlignment="Center"
                       Margin="15 0 0 0" />

            <TextBlock Grid.Column="3"
                       Name="userName"
                       Text="Имя Фамилия"
                       FontSize="16px"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0 0 15 0" />
            <Button Grid.Column="4"
                    Content="Выйти"
                    Padding="15 6"
                    Click="LogoutClick" />
        </Grid>

        <ListBox Name="orderList"
                 Grid.Row="2"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="ProductListMouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="black"
                            BorderThickness="1"
                            Background="White">

                        <Grid Height="80">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="black"
                                    BorderThickness="1 0 1 0"
                                    Padding="10 5">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0 0 0 3">
                                        <TextBlock Text="{Binding Product.Article}"
                                                   FontWeight="Bold"
                                                   FontSize="14" />
                                    </StackPanel>

                                    <TextBlock Margin="0 1">
                                        <Run Text="Статус заказа: "
                                             Foreground="Gray" />
                                        <Run Text="{Binding Order.OrderStatus.Name}" />
                                    </TextBlock>

                                    <TextBlock Margin="0 1">
                                        <Run Text="Адрес пункта выдачи: "
                                             Foreground="Gray" />
                                        <Run Text="{Binding Order.Addres.FullAddress, Mode=OneWay}" />
                                    </TextBlock>

                                    <TextBlock Margin="0 1">
                                        <Run Text="Дата заказа: "
                                             Foreground="Gray" />
                                        <Run Text="{Binding Order.OrdrerDate, StringFormat=\{0:dd.MM.yyyy\}}" />
                                    </TextBlock>

                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="2">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="Дата"
                                               HorizontalAlignment="Center"
                                               FontSize="11" />
                                    <TextBlock Text="Доставки"
                                               HorizontalAlignment="Center"
                                               FontSize="11"
                                               Margin="0,0,0,5" />
                                    <TextBlock Text="{Binding Order.DeliveryDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Name="adminPanel"
                    Visibility="Collapsed"
                    Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Name="productsButton"
                    Content="Товары"
                    Padding="10"
                    Margin="10"
                    Background="Transparent"
                    FontWeight="Bold"
                    Click="ProductsClick" />

            <Button Name="addButton"
                    Content="Добавить новый заказ"
                    Visibility="Collapsed"
                    Padding="10"
                    Margin="10"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="AddClick" />

        </StackPanel>
    </Grid>
</Window>
